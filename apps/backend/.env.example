# Copy this file to .env in the same folder, then fill in real values.
# Never commit the actual .env file (it's already in .gitignore).

# Firebase Admin SDK service account JSON, as a single-line string.
# Get it from: Firebase Console > Project Settings > Service Accounts >
# Generate new private key.
#
# For local dev, prefer the Firebase Local Emulator Suite or a dedicated
# dev/staging Firebase project instead of pointing this at production.
FIREBASE_SERVICE_ACCOUNT=

# Local Express server port (optional, defaults to 3001).
PORT=3001
